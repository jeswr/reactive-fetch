{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noEmit": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false
  },
  "include": ["playwright.config.ts", "fixtures/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts"]
}
