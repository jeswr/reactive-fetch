{
  "name": "@jeswr/solid-reactive-fetch-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for @jeswr/solid-reactive-fetch and related packages",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/reactive-fetch.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "pnpm --filter './packages/*' -r build",
    "dev": "pnpm --filter './packages/*' -r --parallel dev",
    "dev:testbed": "node scripts/dev-testbed.mjs",
    "dev:css": "node scripts/dev-css.mjs",
    "test": "pnpm --filter './packages/*' -r test",
    "test:watch": "pnpm --filter './packages/*' -r --parallel test:watch",
    "typecheck": "pnpm --filter './packages/*' -r typecheck",
    "test:e2e": "pnpm --filter @jeswr/reactive-fetch-e2e test",
    "test:e2e:ui": "pnpm --filter @jeswr/reactive-fetch-e2e test:ui",
    "test:e2e:install": "pnpm --filter @jeswr/reactive-fetch-e2e install-browsers",
    "demo:record": "node scripts/demo-record.mjs",
    "clean": "pnpm --filter './packages/*' -r clean && rimraf node_modules",
    "release": "pnpm build && pnpm exec multi-semantic-release --ignore-private-packages --deps.bump=satisfy --deps.prefix='^'"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@solid/community-server": "^7.1.9",
    "@vitest/coverage-v8": "^4.1.4",
    "multi-semantic-release": "^3.1.0",
    "open": "^11.0.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
