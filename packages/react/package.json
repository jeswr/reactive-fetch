{
  "name": "@jeswr/solid-reactive-fetch-react",
  "version": "0.0.0",
  "description": "React hooks for @jeswr/solid-reactive-fetch",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/reactive-fetch.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/jeswr/reactive-fetch/tree/main/packages/react",
  "bugs": "https://github.com/jeswr/reactive-fetch/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@jeswr/solid-reactive-fetch": "workspace:*",
    "@uvdsl/solid-oidc-client-browser": "^0.2.0",
    "react": ">=18"
  },
  "keywords": [
    "solid",
    "solid-oidc",
    "react",
    "hooks"
  ],
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
