{
  "name": "@jeswr/solid-reactive-fetch-driver-prompt",
  "version": "0.0.0",
  "description": "WebID driver for @jeswr/solid-reactive-fetch that uses the OS-native window.prompt() to collect a WebID, instead of the popup's built-in form. Useful in kiosk apps, deeply restricted CSPs, or accessibility-tooling contexts that prefer native dialogs.",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/reactive-fetch.git",
    "directory": "packages/driver-prompt"
  },
  "homepage": "https://github.com/jeswr/reactive-fetch/tree/main/packages/driver-prompt",
  "bugs": "https://github.com/jeswr/reactive-fetch/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "solid",
    "solid-oidc",
    "reactive-fetch",
    "webid",
    "driver",
    "prompt"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2"
  },
  "dependencies": {
    "@jeswr/solid-reactive-fetch-shared": "workspace:*"
  }
}
