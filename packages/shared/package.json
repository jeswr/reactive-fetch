{
  "name": "@jeswr/solid-reactive-fetch-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Internal shared primitives for @jeswr/solid-reactive-fetch and @jeswr/solid-reactive-fetch-prompt — not published to npm.",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/reactive-fetch.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./callback": {
      "types": "./dist/callback/index.d.ts",
      "import": "./dist/callback/index.js",
      "default": "./dist/callback/index.js"
    },
    "./sw": {
      "types": "./dist/sw/index.d.ts",
      "import": "./dist/sw/index.js",
      "default": "./dist/sw/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@uvdsl/solid-oidc-client-browser": "^0.2.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^25.6.0",
    "@uvdsl/solid-oidc-client-browser": "^0.2.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2"
  },
  "dependencies": {
    "@jeswr/fetch-rdf": "github:jeswr/fetch-rdf#main",
    "@rdfjs/wrapper": "^0.32.0",
    "@solid/object": "^0.5.0",
    "n3": "^2.0.3"
  }
}
