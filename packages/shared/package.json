{
  "name": "@jeswr/solid-reactive-fetch-shared",
  "version": "0.0.0",
  "description": "Shared primitives for @jeswr/solid-reactive-fetch and its WebID drivers — session bootstrap, popup orchestration, error hierarchy, callback-page handlers, and the WebIdDriver contract.",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/reactive-fetch.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/jeswr/reactive-fetch/tree/main/packages/shared",
  "bugs": "https://github.com/jeswr/reactive-fetch/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./callback": {
      "types": "./dist/callback/index.d.ts",
      "import": "./dist/callback/index.js",
      "default": "./dist/callback/index.js"
    },
    "./sw": {
      "types": "./dist/sw/index.d.ts",
      "import": "./dist/sw/index.js",
      "default": "./dist/sw/index.js"
    },
    "./test-helpers": {
      "types": "./test/helpers/index.ts",
      "import": "./test/helpers/index.ts",
      "default": "./test/helpers/index.ts"
    },
    "./test-setup": {
      "types": "./test/setup.ts",
      "import": "./test/setup.ts",
      "default": "./test/setup.ts"
    },
    "./dist-smoke": {
      "types": "./test/distSmoke.ts",
      "import": "./test/distSmoke.ts",
      "default": "./test/distSmoke.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@uvdsl/solid-oidc-client-browser": "^0.2.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^25.6.0",
    "@uvdsl/solid-oidc-client-browser": "^0.2.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2"
  },
  "dependencies": {
    "@jeswr/fetch-rdf": "^0.1.0",
    "@rdfjs/wrapper": "^0.32.0",
    "@solid/object": "^0.5.0",
    "n3": "^2.0.3"
  }
}
