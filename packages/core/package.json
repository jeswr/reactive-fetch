{
  "name": "@jeswr/solid-reactive-fetch",
  "version": "0.0.0",
  "description": "Reactive authenticated fetch for Solid applications — auth is triggered automatically by 401s and webId reads, via a popup flow",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/reactive-fetch.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jeswr/reactive-fetch/tree/main/packages/core",
  "bugs": "https://github.com/jeswr/reactive-fetch/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./callback": {
      "types": "./dist/callback/index.d.ts",
      "import": "./dist/callback/index.js",
      "default": "./dist/callback/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@uvdsl/solid-oidc-client-browser": "^0.2.0"
  },
  "keywords": [
    "solid",
    "solid-oidc",
    "oidc",
    "dpop",
    "authentication",
    "fetch",
    "reactive",
    "webid",
    "popup"
  ],
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/content-type": "^1.1.9",
    "@types/n3": "^1.26.1",
    "@types/node": "^25.6.0",
    "@types/rdfjs__dataset": "^2.0.7",
    "@uvdsl/solid-oidc-client-browser": "^0.2.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2"
  },
  "dependencies": {
    "@rdfjs/dataset": "^2.0.2",
    "@rdfjs/wrapper": "^0.34.0",
    "@solid/object": "^0.5.0",
    "content-type": "^1.0.5",
    "jsonld-streaming-parser": "^5.0.1",
    "n3": "^2.0.3"
  }
}
